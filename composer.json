{
    "name": "daemon8/demo-symfony",
    "type": "project",
    "license": "MIT",
    "description": "Symfony 7 demo application exercising every daemon8/symfony subscriber end-to-end.",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        { "type": "path", "url": "../daemonai/sdks/php", "options": { "symlink": true } },
        { "type": "path", "url": "../daemonai/sdks/php-symfony", "options": { "symlink": true } }
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "daemon8/php": "@dev",
        "daemon8/symfony": "@dev",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.3",
        "symfony/console": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/http-client": "^7.1",
        "symfony/mailer": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/var-exporter": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0",
        "squizlabs/php_codesniffer": "^3.10",
        "symfony/browser-kit": "^7.1",
        "symfony/debug-bundle": "^7.1",
        "symfony/maker-bundle": "^1.50",
        "symfony/phpunit-bridge": "^7.1",
        "symfony/stopwatch": "^7.1",
        "symfony/web-profiler-bundle": "^7.1"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "symfony/flex": false,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "analyse": "php vendor/bin/phpstan analyse --no-progress",
        "cs": "php vendor/bin/phpcs",
        "cs:fix": "php vendor/bin/phpcbf",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "check": ["@analyse", "@cs", "@test"],
        "tour": "@php bin/console daemon8:tour",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#fdba74,#86efac\" --names=server,messenger,daemon8 --kill-others \"symfony serve\" \"php bin/console messenger:consume async -vv\" \"daemon8 tail\""
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis, code style, and the test suite.",
        "dev": "Boot symfony serve + messenger:consume + daemon8 tail in parallel via concurrently.",
        "tour": "Print the interactive tour — routes, console commands, MCP tools.",
        "test": "Run the PHPUnit suite (requires the daemon8 binary on PATH)."
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    }
}
